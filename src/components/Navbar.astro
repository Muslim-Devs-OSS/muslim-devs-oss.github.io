---
interface NavLink {
  label: string;
  href: string;
}

const githubOrgUrl = "https://github.com/Muslim-Devs-OSS/";
const discordInviteUrl = "https://discord.com/invite/RCVW5Es6pQ";

const currentPath = Astro.url.pathname;

const leftLinks: NavLink[] = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects" },
];

const rightLinks: NavLink[] = [
  { label: "Join Community", href: discordInviteUrl },
  { label: "View Github", href: githubOrgUrl },
];
---

<nav
  class="fixed top-4 md:top-6 left-1/2 -translate-x-1/2 w-[calc(100%-1.5rem)] md:w-[calc(100%-3rem)] max-w-7xl z-50 bg-surface-container-high/90 backdrop-blur-lg rounded-2xl md:rounded-full border border-surface-container-highest shadow-[0_4px_20px_rgba(0,255,133,0.1)] px-5 md:px-8 transition-all duration-300"
>
  <div class="flex items-center justify-between h-16 w-full relative">
    <!-- Left Navigation Links (Desktop) -->
    <div class="hidden md:flex items-center justify-start gap-8 w-1/3">
      {
        leftLinks.map((link) => (
          (() => {
            const isActive =
              link.href === "/"
                ? currentPath === "/"
                : currentPath === link.href || currentPath.startsWith(`${link.href}/`);

            return (
          <a
            class:list={[
              "font-inter tracking-tight text-sm font-medium transition-all duration-300 active:scale-95 cursor-pointer",
              isActive
                ? "text-primary-container border-b border-primary-container pb-1 hover:text-primary-fixed"
                : "text-on-surface-variant hover:text-primary-container",
            ]}
            href={link.href}
          >
            {link.label}
          </a>
            );
          })()
        ))
      }
    </div>

    <!-- Center Brand Logo (Desktop) / Left Logo (Mobile) -->
    <div class="flex justify-start md:justify-center w-auto md:w-1/3">
      <a
        class="font-mono font-bold text-primary-container text-[1.15rem] md:text-xl tracking-tighter hover:text-primary-fixed transition-colors duration-300"
        href="/"
      >
        &lt; Muslim Devs /&gt;
      </a>
    </div>

    <!-- Right Navigation Links (Desktop) -->
    <div class="hidden md:flex items-center justify-end gap-8 w-1/3">
      {
        rightLinks.map((link) => (
          <a
            class="font-inter tracking-tight text-sm font-medium text-on-surface-variant hover:text-primary-container transition-all duration-300 active:scale-95 cursor-pointer"
            href={link.href}
            target="_blank"
            rel="noreferrer"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Hamburger (Mobile) -->
    <div class="flex md:hidden justify-end w-auto">
      <button
        id="mobile-menu-btn"
        class="text-on-surface-variant hover:text-primary-container focus:outline-none flex items-center justify-center p-1 active:scale-95 transition-transform"
        aria-label="Toggle menu"
      >
        <span class="material-symbols-outlined text-[28px]">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden flex-col items-start gap-2 pb-5 pt-3 border-t border-surface-container-highest"
  >
    {
      [...leftLinks, ...rightLinks].map((link) => {
        const isLeftLink = leftLinks.some(l => l.href === link.href);
        const isActive = isLeftLink && (
          link.href === "/"
            ? currentPath === "/"
            : currentPath === link.href || currentPath.startsWith(`${link.href}/`)
        );
        
        return (
          <a
            class:list={[
              "w-full font-inter tracking-tight text-base font-medium transition-all duration-300 active:scale-95 cursor-pointer px-4 py-3 rounded-xl",
              isActive
                ? "text-primary-container bg-primary-container/10"
                : "text-on-surface-variant hover:text-primary-container hover:bg-surface-container-highest/50",
            ]}
            href={link.href}
            target={!isLeftLink ? "_blank" : undefined}
            rel={!isLeftLink ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        );
      })
    }
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
      menu.classList.toggle("flex");
    });
  }
</script>
