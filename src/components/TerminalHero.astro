---

---

<section
  class="relative overflow-hidden flex flex-col justify-center items-center py-xl pt-[120px]"
>
  <!-- Ethereal Glow & Watermark -->
  <div
    class="absolute inset-0 flex items-center justify-center pointer-events-none z-0"
  >
    <div
      class="w-[600px] h-[600px] bg-primary-container/10 rounded-full blur-[120px] glow-pulse"
    >
    </div>
    <div
      class="absolute text-[12vw] tracking-tighter watermark-text font-bold uppercase select-none opacity-50 z-0 font-inter"
    >
      BISMILLAH
    </div>
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 w-full flex flex-col lg:flex-row items-center gap-xl"
  >
    <!-- Left: Typography -->
    <div class="w-full lg:w-1/2 flex flex-col items-start gap-md">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 bg-primary-container/10 rounded-full border border-primary-container/20"
      >
        <span
          class="material-symbols-outlined text-primary-container text-[16px]"
          style="font-variation-settings: 'FILL' 1;">terminal</span
        >
        <span class="text-primary-container text-sm font-medium tracking-wider"
          >SYSTEM INITIALIZED</span
        >
      </div>

      <h1
        class="text-5xl md:text-6xl font-bold text-on-background leading-tight tracking-tight"
      >
        Code with <span class="text-primary-container">Purpose.</span><br />
        Build for the <span
          class="text-on-background bg-surface-variant px-2 rounded-sm ml-1"
          >Ummah.</span
        >
      </h1>

      <p class="text-lg text-on-surface-variant mt-1 font-inter">
        Join a global community of engineers bridging the gap between
        faith-based values and cutting-edge open-source technology. Define your
        legacy in lines of code.
      </p>

      <div class="flex items-center gap-sm mt-md">
        <button
          class="cursor-pointer px-8 py-3 bg-primary-container text-on-primary-container hover:bg-primary transition-colors rounded text-sm font-medium flex items-center gap-2 active:scale-95 transition-all"
        >
          <span class="material-symbols-outlined">forum</span>
          Join Discord
        </button>
        <button
          class="cursor-pointer px-8 py-3 bg-transparent text-primary-container border border-primary-container hover:bg-primary-container/10 transition-colors rounded text-sm font-medium flex items-center gap-2 active:scale-95 transition-all"
        >
          <span class="material-symbols-outlined">code</span>
          View GitHub
        </button>
      </div>
    </div>

    <!-- Right: The Terminal Overlay -->
    <div class="w-full lg:w-1/2 mt-lg lg:mt-0">
      <div
        class="bg-surface-container-lowest/90 backdrop-blur-md rounded-xl border border-surface-container-highest shadow-2xl overflow-hidden relative"
      >
        <!-- Terminal Header -->
        <div
          class="flex items-center px-4 py-3 border-b border-surface-container-highest bg-surface-container-low"
        >
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
          </div>
          <div
            class="mx-auto text-on-surface-variant font-mono text-sm opacity-60"
          >
            bash — root@ummah-node — 80x24
          </div>
        </div>

        <!-- Terminal Body -->
        <div
          class="p-6 font-mono text-sm text-on-surface-variant h-[380px] overflow-hidden flex flex-col gap-2"
        >
          <div class="flex">
            <span class="text-primary-container mr-2">➜</span>
            <span class="text-secondary-fixed">~</span>
            <span class="ml-2 text-white">cat network_info.sh</span>
          </div>
          <div class="text-outline"># Loading Muslim Devs Network Info...</div>
          <div class="text-white mt-2">
            <span class="text-primary-container font-bold">Mission:</span> Serving
            the Ummah through Open Source
          </div>
          <div class="text-white">
            <span class="text-primary-container font-bold">Values:</span> Ihsan, Maslaha,
            Excellence
          </div>
          <div class="text-white">
            <span class="text-primary-container font-bold">Community:</span> 500+
            developers worldwide
          </div>
          <br />
          <div class="text-outline"># System Status</div>
          <div class="text-outline">
            &gt; Nodes operational across 40+ countries.
          </div>
          <div class="text-outline">
            &gt; Ready to accept new contributors...
          </div>
          <br />
          <div class="mt-4 text-outline flex items-center">
            <span class="text-primary-container mr-2">➜</span>
            <span class="text-secondary-fixed">~</span>
            <span class="animate-pulse ml-2 text-white">_</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .glow-pulse {
    box-shadow: 0 0 60px rgba(0, 255, 133, 0.15);
  }
  .watermark-text {
    color: rgba(255, 255, 255, 0.03);
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.05);
  }
</style>
