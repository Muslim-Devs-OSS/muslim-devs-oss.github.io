---
interface FooterLink {
  label: string;
  href: string;
  icon: string;
}

const githubOrgUrl = "https://github.com/Muslim-Devs-OSS/";
const discordInviteUrl = "https://discord.com/invite/RCVW5Es6pQ";

const projectLinks: FooterLink[] = [
  { label: "GitHub", href: githubOrgUrl, icon: "code" },
  { label: "Documentation", href: "#", icon: "menu_book" },
];

const communityLinks: FooterLink[] = [
  { label: "Discord", href: discordInviteUrl, icon: "groups" },
  { label: "Ethics Guidelines", href: "#", icon: "gavel" },
];

const legalLinks: FooterLink[] = [
  { label: "Privacy", href: "#", icon: "privacy_tip" },
  { label: "Terms", href: "#", icon: "description" },
];
---

<footer
  class="bg-surface-container-lowest/90 backdrop-blur-md border-t border-primary-container/20 relative overflow-hidden mt-xl"
>
  <!-- Subtle Geometric Watermark -->
  <div
    class="absolute inset-0 opacity-5 pointer-events-none"
    style="background-image: repeating-linear-gradient(45deg, transparent, transparent 8px, #ffffff 8px, #ffffff 9px);"
  >
  </div>

  <div
    class="w-full max-w-7xl mx-auto px-8 py-12 grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10"
  >
    <!-- Column 1: Brand & CTA -->
    <div class="md:col-span-1 flex flex-col gap-6">
      <div>
        <span
          class="text-lg font-black text-primary-container mb-2 block tracking-tight"
          >Muslim Devs</span
        >
        <p class="text-base text-on-surface-variant">
          Bridging faith and cutting-edge technology for the global Ummah.
        </p>
      </div>
      <a
        class="group relative flex items-center justify-center gap-2 px-4 py-3 bg-primary-container text-on-primary-container rounded-lg text-sm font-medium transition-all duration-200 hover:shadow-[0_4px_20px_rgba(0,255,133,0.15)] overflow-hidden cursor-pointer"
        href={discordInviteUrl}
        target="_blank"
        rel="noreferrer"
      >
        <span
          class="material-symbols-outlined text-xl"
          style="font-variation-settings: 'FILL' 1;">forum</span
        >
        <span>Join our Discord</span>
        <div
          class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
        >
        </div>
      </a>
    </div>

    <!-- Column 2: Project -->
    <div class="flex flex-col gap-4 md:ml-auto">
      <h3
        class="font-inter text-xs uppercase tracking-widest text-on-surface-variant/50"
      >
        Project Links
      </h3>
      <ul class="flex flex-col gap-3">
        {
          projectLinks.map((link) => (
            <li>
              <a
                class="text-on-surface-variant hover:text-primary-container hover:translate-x-1 transition-all duration-200 cursor-pointer text-base flex items-center gap-2 py-2 md:py-0"
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noreferrer" : undefined}
              >
                <span class="material-symbols-outlined text-sm opacity-60">
                  {link.icon}
                </span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Column 3: Community -->
    <div class="flex flex-col gap-4 md:ml-auto">
      <h3
        class="font-inter text-xs uppercase tracking-widest text-on-surface-variant/50"
      >
        Community Links
      </h3>
      <ul class="flex flex-col gap-3">
        {
          communityLinks.map((link) => (
            <li>
              <a
                class="text-on-surface-variant hover:text-primary-container hover:translate-x-1 transition-all duration-200 cursor-pointer text-base flex items-center gap-2 py-2 md:py-0"
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noreferrer" : undefined}
              >
                <span class="material-symbols-outlined text-sm opacity-60">
                  {link.icon}
                </span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Column 4: Legal -->
    <div class="flex flex-col gap-4 md:ml-auto">
      <h3
        class="font-inter text-xs uppercase tracking-widest text-on-surface-variant/50"
      >
        Legal Links
      </h3>
      <ul class="flex flex-col gap-3">
        {
          legalLinks.map((link) => (
            <li>
              <a
                class="text-on-surface-variant hover:text-primary-container hover:translate-x-1 transition-all duration-200 cursor-pointer text-base flex items-center gap-2 py-2 md:py-0"
                href={link.href}
              >
                <span class="material-symbols-outlined text-sm opacity-60">
                  {link.icon}
                </span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Separator & Copyright -->
  <div class="w-full border-t border-surface-container-highest">
    <div
      class="max-w-7xl mx-auto px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="font-mono text-sm text-on-surface-variant/50">
        © 2026 Muslim Devs. Built for the Ummah with Ihsan.
      </p>
      <div class="flex gap-6 text-on-surface-variant/50">
        <a
          aria-label="Share"
          class="hover:text-primary-container transition-colors duration-200 cursor-pointer"
          href="#"
        >
          <span class="material-symbols-outlined">share</span>
        </a>
        <a
          aria-label="Email"
          class="hover:text-primary-container transition-colors duration-200 cursor-pointer"
          href="#"
        >
          <span class="material-symbols-outlined">mail</span>
        </a>
      </div>
    </div>
  </div>
</footer>
