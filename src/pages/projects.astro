---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { projects, toProjectSlug } from "../data/projects";

const projectsWithSlug = projects.map((project) => ({
  ...project,
  projectSlug: toProjectSlug(project),
}));
---

<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Browse Muslim Devs Open Source projects and jump to each README, website, and GitHub repository."
    />
    <title>Projects | Muslim Devs Open Source</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@700&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-on-background min-h-screen flex flex-col font-inter antialiased">
    <Navbar />

    <main class="w-full max-w-7xl mx-auto px-6 md:px-10 pt-32 pb-20 flex-1">
      <section class="max-w-3xl">
        <p class="text-primary-container font-mono text-sm tracking-wide uppercase">Projects</p>
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mt-3">Builds for the Ummah</h1>
      </section>

      <section class="grid gap-6 md:grid-cols-2 mt-10">
        {
          projectsWithSlug.map((project) => (
            <article class="bg-surface-container border border-surface-container-highest rounded-2xl p-6 shadow-[0_4px_20px_rgba(0,255,133,0.08)]">
              <a href={`/projects/${project.projectSlug}`} class="block group rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-container/70">
                <div class="flex items-start justify-between gap-3">
                  <h2 class="text-2xl font-semibold tracking-tight group-hover:text-primary-container transition-colors">{project.projectName}</h2>
                  <span
                    class:list={[
                      "text-xs font-medium px-3 py-1 rounded-full border",
                      project.projectType === "Featured"
                        ? "bg-primary-container/10 text-primary-container border-primary-container/40"
                        : "bg-secondary-container/25 text-secondary border-secondary/40",
                    ]}
                  >
                    {project.projectType}
                  </span>
                </div>

                <p class="mt-4 text-on-surface-variant leading-relaxed">{project.projectDescription}</p>

                    {
                      project.projectAuthor && (
                        <p class="mt-3 text-sm text-on-surface-variant/90">
                          <span class="text-primary-container font-medium">Author:</span>
                          {" "}
                          {project.projectAuthor}
                        </p>
                      )
                    }

                <div class="mt-5">
                  <p class="text-sm text-on-surface-variant mb-2">Tech Stack</p>
                  <div class="flex flex-wrap gap-2">
                    {project.techStack.map((tech) => (
                      <span class="text-xs bg-surface-container-high px-2.5 py-1 rounded-md border border-surface-container-highest">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>

                <span class="inline-flex mt-6 text-sm text-primary-container group-hover:text-primary-fixed transition-colors">
                  View Project Details ->
                </span>
              </a>

              <div class="mt-5 flex flex-wrap gap-3">
                {
                  project.projectWebsite ? (
                    <a
                      href={project.projectWebsite}
                      class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-secondary/50 text-secondary hover:text-primary-container hover:border-primary-container/50 transition-colors text-sm"
                      target="_blank"
                      rel="noreferrer"
                    >
                      View Website
                    </a>
                  ) : (
                    <span class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-surface-bright text-on-surface-variant/70 text-sm cursor-not-allowed" aria-disabled="true">
                      View Website
                    </span>
                  )
                }

                    {
                      project.projectGithub ? (
                        <a
                          href={project.projectGithub}
                          class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-secondary/50 text-secondary hover:text-primary-container hover:border-primary-container/50 transition-colors text-sm"
                          target="_blank"
                          rel="noreferrer"
                        >
                          View Github
                        </a>
                      ) : (
                        <span class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-surface-bright text-on-surface-variant/70 text-sm cursor-not-allowed" aria-disabled="true">
                          Repo Not Open Yet
                        </span>
                      )
                    }

                    {
                      project.projectGithubSecondary && (
                        <a
                          href={project.projectGithubSecondary}
                          class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-secondary/50 text-secondary hover:text-primary-container hover:border-primary-container/50 transition-colors text-sm"
                          target="_blank"
                          rel="noreferrer"
                        >
                          {project.projectGithubSecondaryLabel || "View Secondary Repo"}
                        </a>
                      )
                    }
              </div>
            </article>
          ))
        }
      </section>
    </main>

    <Footer />
  </body>
</html>
